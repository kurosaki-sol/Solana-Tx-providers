  "methods": {
    "sendTransaction": {
      "description": "Submit a signed transaction for landing on Solana via SWQoS",
      "http_method": "POST",
      "path": "/",
      "query_params": {
        "api-key": "required - your API token",
        "anti-mev": "optional - set to 'true' (case-sensitive) to enable anti-MEV protection",
        "secure": "optional - set to 'true' for secure mode"
      },
      "content_type": "application/json",
      "request_format": {
        "jsonrpc": "2.0",
        "id": "string (UUID recommended)",
        "method": "sendTransaction",
        "params": [
          "<base64_encoded_signed_transaction>",
          {
            "encoding": "base64"
          }
        ]
      },
      "response_success": {
        "jsonrpc": "2.0",
        "id": "string",
        "result": "transaction_signature"
      },
      "error_codes": {
        "403_expired": {
          "code": 403,
          "message": "api-key has expired"
        },
        "403_invalid_method": {
          "code": 403,
          "message": "only support sendTransaction method"
        },
        "419_rate_limit": {
          "code": 419,
          "message": "rate limit exceeded"
        }
      }
    },
    "sendTransaction_binary": {
      "description": "Submit a signed transaction as raw binary bytes (RECOMMENDED - fastest method)",
      "http_method": "POST",
      "path": "/txb",
      "query_params": {
        "api-key": "required",
        "anti-mev": "optional - 'true' for anti-MEV",
        "secure": "optional - 'true' for secure mode"
      },
      "content_type": "application/octet-stream",
      "request_format": "raw binary transaction bytes (e.g. tx.MarshalBinary() in Go, transaction.serialize() in JS)",
      "url_example": "http://de.0slot.trade/txb?api-key=YOUR_KEY",
      "response_codes": {
        "200": "ok - transaction submitted successfully",
        "403": "API key null, nonexistent, or expired",
        "419": "rate limit exceeded",
        "500": "ok - submission failed"
      },
      "note": "Avoids base64 encoding overhead (~30% size increase). Keeps TX within single TCP packet. Strongly recommended for lowest latency."
    },
    "sendTransaction_plaintext": {
      "description": "Submit a base64-encoded transaction as plain text (simpler than JSON-RPC)",
      "http_method": "POST",
      "path": "/",
      "content_type": "text/plain",
      "request_format": "base64-encoded transaction string as plain text body",
      "note": "Simpler than JSON but still has base64 overhead. Binary method preferred."
    }
  },
  "features": {
    "swqos": {
      "name": "Stake-Weighted Quality of Service",
      "description": "Uses staked validator connections for priority transaction landing",
      "available": true
    },
    "anti_mev": {
      "name": "Anti-MEV Protection",
      "description": "Maintains real-time blacklist of malicious validators. When enabled, withholds transactions from compromised leaders and resubmits to next safe leader.",
      "parameter": "&anti-mev=true",
      "value_must_be": "true (case-sensitive; '1' and 'yes' do NOT work)",
      "guarantee": "No 100% guarantee against sandwich attacks",
      "latency_impact": "May slightly delay transactions if malicious leaders detected"
    },
    "jito_sandwich_mitigation": {
      "name": "Jito Sandwich Mitigation (jitodontfront)",
      "description": "Add a pubkey starting with 'jitodontfront' to any instruction. Jito rejects bundles unless the protected TX is at index 0.",
      "example_keys": [
        "jitodontfront111111111111111111111111111111",
        "jitodontfront111111111111111111111111111123"
      ],
      "impact_on_speed": "none"
    },
    "durable_nonce": {
      "name": "Durable Nonce Support",
      "description": "Supports durable nonce transactions for multi-landing. Can submit same signed TX to multiple endpoints concurrently.",
      "nonce_account_data_layout": {
        "version": "bytes 0-3 (4 bytes)",
        "authorized_pubkey": "bytes 8-39 (32 bytes)",
        "nonce_hash": "bytes 40-71 (32 bytes)",
        "fee_calculator": "bytes 72-79 (8 bytes)"
      }
    },
    "keepalive": {
      "name": "HTTP Keep-Alive",
      "timeout_seconds": 65,
      "recommended_ping_interval_seconds": 60,
      "health_endpoint": "http://{region}.0slot.trade/health",
      "note": "Health checks are unrestricted and do not count toward TPS limits"
    },
    "binary_tx": {
      "name": "Binary Transaction Submission",
      "description": "Raw binary TX bytes via /txb endpoint. Eliminates base64 encoding overhead (~30% size reduction). Keeps TX in single TCP packet.",
      "recommended": true
    },
    "cors_skip": {
      "name": "CORS Preflight Skip",
      "description": "Skips CORS preflight checks, saving tens of milliseconds"
    },
    "multi_region": {
      "name": "Multi-Region Servers",
      "regions": ["New York", "Frankfurt", "Amsterdam", "Tokyo", "Los Angeles"],
      "note": "Contact support for optimal server selection based on your location"
    },
    "http_faster": {
      "name": "HTTP vs HTTPS",
      "description": "HTTP is slightly faster than HTTPS. Both supported. Use HTTP for lowest latency."
    }
  },
  "supported_encodings": ["base64", "binary (raw bytes via /txb)"],
