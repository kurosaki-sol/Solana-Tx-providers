  "rate_limits": {
    "scope": "per_region",
    "notes": "Multi-region sends don't count against the same limit",
    "qos_penalty": "Applied if landing rate drops below expected threshold",
    "custom_limits": "Available for high-volume users (contact Temporal)"
  },
  "methods": {
    "sendTransaction_jsonrpc": {
      "path": "/",
      "full_url_example": "https://nozomi.temporal.xyz/?c=YOUR_API_KEY",
      "http_method": "POST",
      "content_type": "application/json",
      "request_body": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "sendTransaction",
        "params": ["<BASE64_ENCODED_TX_BYTES>", {"encoding": "base64"}]
      },
      "response": "JSON-RPC response with transaction signature",
      "encoding": "base64 (MUST be explicitly specified; Solana defaults to base58)",
      "notes": "Standard Solana JSON-RPC compatible"
    },
    "sendTransaction2_api_v2": {
      "path": "/api/sendTransaction2",
      "full_url_example": "https://nozomi.temporal.xyz/api/sendTransaction2?c=YOUR_API_KEY",
      "http_method": "POST",
      "content_type": "text/plain",
      "request_body": "<BASE64_ENCODED_TX_BYTES>",
      "response": "Empty body with 200 OK (no signature returned)",
      "encoding": "base64",
      "advantages": [
        "No CORS preflight needed",
        "Faster encoding than JSON-RPC",
        "Lower overhead"
      ]
    },
    "sendBatch": {
      "path": "/api/sendBatch",
      "full_url_example": "https://nozomi.temporal.xyz/api/sendBatch?c=YOUR_API_KEY",
      "http_method": "POST",
      "content_type": "application/octet-stream",
      "request_body": "Binary: concatenation of length-prefixed transactions [u16_big_endian_length][tx_bytes]...",
      "response": "Empty body with 200 OK on success; 400 with plain text error description on failure",
      "encoding": "raw binary with big-endian u16 length prefix per transaction",
      "limits": {
        "max_transactions_per_batch": 16,
        "min_transaction_size_bytes": 66,
        "max_transaction_size_bytes": 1232,
        "max_body_size_bytes": 19744
      },
      "notes": "Stream-processed; partial success possible without rollback. Transactions forwarded as parsed, so if TX N fails, TX 1..N-1 may already be accepted."
    },
    "tip_floor": {
      "path": "/tip_floor",
      "full_url": "https://api.nozomi.temporal.xyz/tip_floor",
      "http_method": "GET",
      "response_schema": {
        "time": "ISO 8601 timestamp",
        "landed_tips_25th_percentile": "number",
        "landed_tips_50th_percentile": "number",
        "landed_tips_75th_percentile": "number",
        "landed_tips_95th_percentile": "number",
        "landed_tips_99th_percentile": "number"
      }
    },
    "tip_stream": {
      "url": "wss://api.nozomi.temporal.xyz/tip_stream",
      "protocol": "WebSocket",
      "response_schema": {
        "time": "ISO 8601 timestamp",
        "landed_tips_25th_percentile": "number",
        "landed_tips_50th_percentile": "number",
        "landed_tips_75th_percentile": "number",
        "landed_tips_95th_percentile": "number",
        "landed_tips_99th_percentile": "number"
      }
    },
    "ping": {
      "path": "/ping",
      "http_method": "GET",
      "notes": "Keep-alive health check endpoint"
    }
  },
  "features": {
    "tip_only_on_success": true,
    "higher_tips_prioritized": true,
    "delivery_paths": ["Jito validators", "Harmonic bundles"],
    "tcp_keepalive": {
      "timeout_seconds": 65,
      "max_requests_per_connection": 1000,
      "recommended_ping_interval_seconds": 60
    },
    "supported_languages": ["Rust", "Python", "JavaScript", "TypeScript", "cURL"],
    "no_full_rpc": "Nozomi is NOT a full RPC. Use a separate RPC (e.g. Helius) for getLatestBlockhash and other read calls.",
    "multi_region_send": "Can send to multiple regions simultaneously without rate limit penalty"
  },
  "response_status_codes": {
    "200": "Success",
    "400": "Framing error, size violation, parse failure, or insufficient tip",
    "401": "Invalid or missing API key",
    "429": "Rate limited",
    "500": "Internal server error"
  }
}
