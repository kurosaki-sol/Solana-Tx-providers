      "path": "/v2/sendBinaryTransaction",
      "content_type": "application/octet-stream",
      "http_example": "http://frankfurt.solana.blockrazor.xyz:443/v2/sendBinaryTransaction",
      "https_example": "https://frankfurt.solana.blockrazor.io/v2/sendBinaryTransaction"
    },
    "network_fee_stream": {
      "grpc": "grpc.solana-fee.blockrazor.me:443",
      "tls": true
    },
    "geyser_stream": {
      "frankfurt": "geyserstream-frankfurt.blockrazor.xyz:443",
      "amsterdam": "geyserstream-amsterdam.blockrazor.xyz:443",
      "new_york": "geyserstream-newyork.blockrazor.xyz:443",
      "tokyo": "geyserstream-tokyo.blockrazor.xyz:443"
    },
    "shred_stream": {
      "regions": ["frankfurt", "amsterdam", "tokyo", "new_york"],
      "protocol": "UDP",
      "note": "Provide your IP:Port, receive native UDP shred packets from validators"
    }
  },
  "rate_limits": {
    "send_transaction": {
      "default": "1 TPS",
      "note": "Contact Discord support for TPS increases"
    },
    "network_fee_stream": {
      "tier_4_free": "1 QPS",
      "tier_3": "5 QPS",
      "tier_2": "10 QPS",
      "tier_1": "50 QPS",
      "tier_0_custom": "100 QPS"
    },
    "shred_stream": {
      "tier_2": "1 stream",
      "tier_1": "2 streams",
      "tier_0": "5 streams"
    }
  },
  "methods": {
    "sendTransaction_v1": {
      "endpoint": "POST /sendTransaction",
      "auth_header": "apikey",
      "content_type": "application/json",
      "encoding": ["base64", "base58"],
      "preferred_encoding": "base64",
      "params": {
        "transaction": {
          "type": "string",
          "required": true,
          "description": "Fully signed transaction, base64 or base58 encoded"
        },
        "mode": {
          "type": "string",
          "required": false,
          "default": "fast",
          "values": ["fast", "sandwichMitigation"]
        },
        "safeWindow": {
          "type": "integer",
          "required": false,
          "default": 3,
          "range": "3-13",
          "description": "Number of slots with whitelisted validators; only effective in sandwichMitigation mode"
        },
        "revertProtection": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Enables revert protection; may impact inclusion speed"
        }
      },
      "response": {
        "success": {"signature": "<txn_hash>", "error": ""},
        "error": {"signature": "", "error": "<error message>"}
      },
      "status_codes": {
        "200": "OK - Request processed successfully",
        "400": "BadRequest - Invalid parameters",
        "403": "Forbidden - Auth empty, invalid, or expired",
        "500": "InternalServerError"
      }
    },
    "sendTransaction_v2": {
      "endpoint": "POST /v2/sendTransaction",
      "auth": "query parameter ?auth=<token>",
      "content_type": "text/plain",
      "encoding": ["base64"],
      "params": {
        "transaction": {
          "type": "string",
          "required": true,
          "description": "Base64-encoded fully signed transaction"
        },
        "mode": {
          "type": "string",
          "required": false,
          "default": "fast",
          "values": ["fast", "sandwichMitigation"]
        },
        "safeWindow": {
          "type": "integer",
          "required": false,
          "default": 3,
          "range": "3-13"
        },
        "revertProtection": {
          "type": "boolean",
          "required": false,
          "default": false
        }
      },
      "response": {
        "success": {"signature": "<txn_hash>", "error": ""},
        "error": {"signature": "", "error": "<error message>"}
      },
      "status_codes": {
        "200": "OK",
        "400": "BadRequest",
        "403": "Forbidden",
        "500": "InternalServerError"
      }
    },
    "getTransactionFee": {
      "endpoint": "gRPC GetTransactionFee",
      "server": "grpc.solana-fee.blockrazor.me:443",
      "auth": "gRPC metadata: {\"apiKey\": \"<your_auth>\"}",
      "params": {
        "accounts": {
          "type": "string[]",
          "required": false,
          "description": "Filter by specific wallet addresses; omit for all transactions"
        },
        "percentile": {
          "type": "int32",
          "required": true,
          "values": [25, 50, 75, 95, 99],
          "description": "Quantile level for fee calculation"
        },
        "slotRange": {
          "type": "int32",
          "required": true,
          "range": "1-150",
          "description": "Number of recent confirmed slots to analyze"
        }
      },
      "response": {
        "priorityFee": {
          "percentile": "int32",
          "value": "double (micro-lamports)"
        },
        "tip": {
          "percentile": "int32",
          "value": "double (SOL)"
        }
      }
    },
    "health_v1": {
      "endpoint": "POST /health",
      "auth_header": "apikey"
    },
    "health_v2": {
      "endpoint": "POST /v2/health?auth=<token>",
      "body": "empty"
    }
  },
  "features": {
    "sandwich_mitigation": {
      "description": "Monitors and skips blacklisted validators in real-time",
      "mode": "sandwichMitigation",
      "safe_window_range": "3-13 slots"
    },
    "revert_protection": {
      "description": "Prevents failed transactions from landing on-chain; may reduce inclusion speed"
    },
    "swqos": "Stake-Weighted Quality of Service from high-stake validators",
    "geographic_endpoints": ["frankfurt", "new_york", "tokyo", "amsterdam", "london"],
    "multi_protocol": ["HTTP", "gRPC"],
    "shred_stream": {
      "description": "Native UDP shred packets directly from validators with minimal forwarding hops",
      "regions": ["frankfurt", "amsterdam", "tokyo", "new_york"],
      "pricing_monthly": "$500/stream/region",
      "pricing_annual": "$4800/stream/region ($400/mo)"
    },
    "geyser_stream": {
      "description": "High-performance Solana data streaming via gRPC",
      "replay": "Supports transaction replay for most recent 500 slots (~200 seconds)",
      "data_allowance_tier_2": "20 TiB/cycle",
      "data_allowance_tier_1": "50 TiB/cycle",
      "min_tier": "Tier 2 - Solana"
    },
    "gas_sponsor": {
      "description": "Enables transactions without holding SOL by sponsoring fees and rent",
      "solana_support": "mentioned but not documented in detail (Ethereum-focused docs)"
    },
    "bundle_support_solana": false,
    "bundle_support_note": "Bundles only supported for BSC and Ethereum, not Solana",
    "sdk_languages": ["Go", "Rust", "JavaScript", "TypeScript", "CLI"]
  },
