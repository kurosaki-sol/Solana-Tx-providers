  "features": {
    "front_running_protection": {
      "description": "Scores slot leaders for malicious ordering risk. High-risk leaders are delayed/skipped. Low-risk leaders receive accelerated submission via staked connections.",
      "parameter": "frontRunningProtection=true",
      "note": "Best-effort, no absolute guarantee against attacks."
    },
    "revert_protection": {
      "description": "Prevents failed transactions from landing on-chain, preserving priority fees.",
      "parameter": "revertProtection=true"
    },
    "staked_rpcs": {
      "description": "Send directly to leaders via staked validator connections for fastest inclusion.",
      "parameter": "useStakedRPCs=true",
      "requires": "tip >= 0.001 SOL and frontRunningProtection=false"
    },
    "submit_protection_levels": {
      "SP_LOW": "Fastest, minimal protection",
      "SP_MEDIUM": "Default, balanced",
      "SP_HIGH": "Maximum protection, may delay more slots"
    },
    "ofa_backrun": {
      "description": "Order Flow Auction - allows MEV searchers to backrun your TX, with rebates to your revenueAddress.",
      "parameters": ["allowBackRun=true", "revenueAddress=<wallet>"]
    },
    "atomic_bundles": {
      "description": "Multiple transactions executed atomically via submit-batch with useBundle=true. Sequential, atomic, all-or-nothing modes.",
      "strategies": ["P_SUBMIT_ALL", "P_ABORT_ON_FIRST_ERROR", "P_WAIT_FOR_CONFIRMATION"]
    },
    "snipe_mode": {
      "description": "Dual-path submission via submit-snipe: first TX goes to Jito, second TX goes to bloXroute. Designed for token sniping.",
      "path": "/api/v2/submit-snipe"
    },
    "pumpfun_integration": {
      "description": "Native PumpFun bonding curve + AMM swap building, quotes, and real-time streams for new tokens and swaps.",
      "beta": true
    },
    "jupiter_integration": {
      "description": "Native Jupiter quote, swap, swap-instructions, and route-swap endpoints.",
      "supports_custom_routes": true
    },
    "priority_fee_stream": {
      "description": "Real-time priority fee recommendations from recent slots."
    },
    "bundle_tip_stream": {
      "description": "Real-time bundle tip percentile data with EMA."
    },
    "malicious_validator_detection": {
      "description": "Historical behavior analysis to identify malicious slot leaders. Available via slot-info endpoint (Ultra tier)."
    },
    "transaction_tracing": {
      "description": "Full trace of TX journey: received time, released time, regions, delays. Ultra tier only.",
      "tier_required": "Ultra"
    },
    "quic_submission": {
      "description": "Submit transactions over QUIC for reduced serialization overhead (raw bytes), stream multiplexing (no head-of-line blocking), and faster connection setup. Official SDK is Rust, but any language works if it follows the same connection/submission protocol.",
      "auth": "mTLS — download the client certificate/key from the bloXroute portal (unlike HTTP/WebSocket/gRPC, which use the Authorization header).",
      "sdk": "quic-sdk (Rust)"
    },
    "sdks": ["Go", "Python", "TypeScript", "Rust"],
    "protocols": ["HTTP", "HTTPS", "WebSocket (WSS)", "gRPC", "QUIC (mTLS)"],
    "encoding": "base64 (transaction content)",
    "keep_alive_seconds": 60,
    "performance_tips": {
      "use_http_not_https": "HTTP has lower latency than HTTPS",
      "submit_to_global_and_nearest": "Submit to both global endpoint and 1-2 nearest regional endpoints in parallel",
      "dns": "Use DNS resolvers supporting EDNS Client Subnet (Google DNS 8.8.8.8, OpenDNS)",
      "recommended_config": {
        "frontRunningProtection": false,
        "useStakedRPCs": true,
        "submitProtection": "SP_LOW"
      }
