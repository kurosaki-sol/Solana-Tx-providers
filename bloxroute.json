  "rate_limits": {
    "reset_interval_seconds": 60,
    "cost_per_submit": 1,
    "error_code": 429,
    "tiers": {
      "Introductory": {
        "credits_per_60s": 60
      },
      "Enterprise": {
        "credits_per_60s": 660
      },
      "Enterprise-Elite": {
        "credits_per_60s": 3060
      },
      "Ultra": {
        "credits_per_60s": 9960
      },
      "Build Your Own": {
        "credits_per_60s": "60 + (150 * X)",
        "note": "X = number of $250/month bundles"
      }
    },
    "check_endpoint": "GET /api/v2/rate-limit",
    "credit_costs_per_endpoint": {
      "submit": 1,
      "submit-plain-text": 1,
      "submit-snipe": 1,
      "submit-batch": 1,
      "submit-paladin": 1,
      "balance": 10,
      "rate-limit": 1,
      "transaction": 10,
      "slot-info": 1,
      "trace": 5,
      "priority-fee": 1,
      "blockhash": 1,
      "time": 1,
      "pumpfun_quotes": 1,
      "pumpfun_swap": 1,
      "pumpfun_swap-sol": 1,
      "pumpfun_amm_quotes": 1,
      "pumpfun_amm_swap": 1,
      "jupiter_quotes": 5,
      "jupiter_swap": 5,
      "jupiter_swap-instructions": 5,
      "jupiter_route-swap": 5,
      "note": "Transaction submissions cost 1 credit each. Credits reset every 60 seconds."
    }
  },
  "methods": {
    "core": {
      "submit": {
        "method": "POST",
        "path": "/api/v2/submit",
        "description": "Submit a single signed transaction",
        "protocols": ["HTTP", "WebSocket"],
        "ws_method": "PostSubmit",
        "parameters": {
          "transaction": {
            "type": "TransactionMessage",
            "required": true,
            "description": "Contains 'content' field with base64-encoded raw signed transaction bytes"
          },
          "skipPreFlight": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Disables transaction simulation"
          },
          "frontRunningProtection": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Delays/skips high-risk validators to reduce front-running risk"
          },
          "revertProtection": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Prevents failed transactions from landing on-chain"
          },
          "submitProtection": {
            "type": "enum",
            "required": false,
            "default": "SP_MEDIUM",
            "values": ["SP_LOW", "SP_MEDIUM", "SP_HIGH"],
            "description": "MEV protection level"
          },
          "useStakedRPCs": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Send directly to leaders via staked validator connections. Requires tip >= 0.001 SOL and frontRunningProtection=false"
          },
          "allowBackRun": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Enables OFA submission for MEV rebates"
          },
          "revenueAddress": {
            "type": "string",
            "required": false,
            "description": "Wallet address for MEV rebate (required if allowBackRun=true)"
          }
        },
        "response": {
          "signature": "string (Solana transaction signature)"
        }
      },
      "submit_plain_text": {
        "method": "POST",
        "path": "/api/v2/submit-plain-text",
        "description": "Submit transaction as plain text base64 payload",
        "content_type": "text/plain",
        "body": "Base64-encoded transaction payload directly in body",
        "parameters_in_uri": {
          "skipPreFlight": { "type": "boolean", "default": true },
          "frontRunningProtection": { "type": "boolean", "default": false },
          "revertProtection": { "type": "boolean", "default": false },
          "submitProtection": { "type": "string", "default": "medium", "values": ["low", "medium", "high"] },
          "useStakedRPCs": { "type": "boolean" },
          "allowBackRun": { "type": "boolean" },
          "revenueAddress": { "type": "string" }
        },
        "response": {
          "signature": "string"
        }
      },
      "submit_batch": {
        "method": "POST",
        "path": "/api/v2/submit-batch",
        "description": "Submit multiple signed transactions as a batch/bundle",
        "protocols": ["HTTP", "WebSocket"],
        "ws_method": "PostSubmitBatch",
        "parameters": {
          "entries": {
            "type": "PostSubmitRequestEntry[]",
            "required": true,
            "description": "List of signed transactions, each with 'transaction' (TransactionMessage with base64 content) and optional 'skipPreFlight' (default true)"
          },
          "submitStrategy": {
            "type": "enum",
            "required": false,
            "default": "P_UNKNOWN",
            "values": ["P_SUBMIT_ALL", "P_ABORT_ON_FIRST_ERROR", "P_WAIT_FOR_CONFIRMATION"],
            "description": "Execution strategy for the batch"
          },
          "useBundle": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Execute as atomic bundle"
          }
        },
        "response": {
          "transactions": [
            {
              "signature": "string",
              "error": "string (conditional)",
              "submitted": "boolean"
            }
          ]
        }
      },
      "submit_snipe": {
        "method": "POST",
        "path": "/api/v2/submit-snipe",
        "description": "Dual-path submission: first TX to Jito, second TX to bloXroute. Designed for sniping.",
        "parameters": {
          "entries": {
            "type": "PostSubmitRequestEntry[]",
            "required": true,
            "description": "Array of transactions. First goes to Jito (needs Jito tip >= 0.001 SOL + bloXroute tip >= 0.0001 SOL, no priority fee needed). Second goes to bloXroute (needs priority fee + bloXroute tip)."
          },
          "useStakedRPCs": {
            "type": "boolean",
            "required": false,
            "default": false
          }
        },
        "tip_requirements": {
          "first_tx_jito_tip": ">=0.001 SOL",
          "first_tx_bloxroute_tip": ">=0.0001 SOL",
          "second_tx": "priority fee + bloXroute tip"
        },
        "response": {
          "transactions": [
            {
              "signature": "string",
              "submitted": "boolean",
              "error": "string (if applicable)"
            }
          ]
        }
      },
      "submit_paladin": {
        "method": "POST",
        "path": "/api/v2/submit-paladin",
        "path_note": "Inferred from the naming convention; submit-paladin is listed in the credit-cost table (1 credit) but its dedicated docs page is not yet published as of 2026-07.",
        "description": "Submit a transaction via the Paladin path (Paladin anti-MEV validator-client integration).",
        "credit_cost": 1
      },
      "balance": {
        "method": "GET",
        "path": "/api/v2/balance",
        "description": "Fetch token balances for a wallet",
        "parameters": {
          "ownerAddress": {
            "type": "string",
            "required": true,
            "description": "Address to fetch token balance details"
          }
        },
        "response": {
          "tokens": [
            {
              "symbol": "string",
              "token_mint": "string",
              "settled_amount": "number",
              "unsettled_amount": "number (Openbook only)",
              "open_orders_amount": "number (Openbook only)"
            }
          ]
        }
      },
      "rate_limit": {
        "method": "GET",
        "path": "/api/v2/rate-limit",
        "description": "Check current rate limit usage",
        "parameters": {},
        "response": {
          "accountID": "string",
          "tier": "string",
          "interval": "string",
          "intervalNum": "uint64",
          "limit": "uint64",
          "count": "uint64",
          "reset": "uint64 (unix timestamp)"
        }
      },
      "transaction": {
        "method": "GET",
        "path": "/api/v2/transaction",
        "description": "Get transaction status and details",
        "parameters": {
          "signature": {
            "type": "string",
            "required": true,
            "description": "Signature of a Solana transaction"
          }
        },
        "response": {
          "status": "string (not_found | success | failed)",
          "metadata": {
            "err": "string",
            "errored": "uint64",
            "fee": "uint64",
            "pre_balances": "uint64",
            "post_balances": "uint64",
            "inner_instructions": "array",
            "log_messages": "string",
            "pre_token_balances": "array",
            "post_token_balances": "array"
          },
          "slot": "uint64",
          "block_time": "uint64",
          "version": "int32"
        }
      },
      "slot_info": {
        "method": "GET",
        "path": "/api/v2/system/slot-info",
        "description": "Get slot leader and maliciousness info (Ultra tier only)",
        "tier_required": "Ultra",
        "parameters": {
          "slot": {
            "type": "uint64",
            "required": true,
            "description": "Target slot number"
          }
        },
        "response": {
          "slot": "uint64",
          "leader": "string",
          "malicious": "boolean"
        }
      },
      "trace": {
        "method": "GET",
        "path": "/api/v2/system/trace",
        "description": "Trace a submitted transaction's journey (Ultra tier only)",
        "tier_required": "Ultra",
        "parameters": {
          "signature": {
            "type": "string",
            "required": true,
            "description": "Signature of a submitted transaction"
          }
        },
        "response": {
          "signature": "string",
          "firstReceivedTime": "google.protobuf.Timestamp",
          "firstReleasedTime": "google.protobuf.Timestamp",
          "firstReceivedSlot": "int64",
          "firstReleasedSlot": "int64",
          "firstReceivedRegion": "string",
          "firstReleasedRegion": "string",
          "delayed": "boolean",
          "delayedSlots": "int64"
        }
      },
      "priority_fee": {
        "method": "GET",
        "path": "/api/v2/system/priority-fee",
        "description": "Get recommended priority fee based on recent slots",
        "parameters": {
          "project": {
            "type": "enum",
            "required": true,
            "values": ["P_ALL", "P_JUPITER", "P_RAYDIUM"],
            "description": "Which project to query"
          },
          "percentile": {
            "type": "double",
            "required": false,
            "default": 55,
            "description": "Percentile of previous 100 slots' priority fees"
          }
        },
        "response": {
          "project": "enum",
          "percentile": "double",
          "feeAtPercentile": "uint64 (micro lamports)"
        },
        "note": "Recommended fees capped at 0.1 SOL. Does not guarantee inclusion."
      },
      "blockhash": {
        "method": "GET",
        "path": "/api/v2/system/blockhash",
        "description": "Get a recent Solana blockhash for transaction construction, with an optional slot offset.",
        "parameters": {
          "offset": {
            "type": "uint64",
            "required": false,
            "default": 0,
            "description": "Slot offset from the most recent cached blockhash"
          }
        },
        "response": {
          "blockHash": "string (recent blockhash with the applied offset)",
          "timestamp": "google.protobuf.Timestamp"
        },
        "credit_cost": 1
      },
      "time": {
        "method": "GET",
        "path": "/api/v1/system/time",
        "description": "Return the current server time from Trader API (RFC 3339).",
        "parameters": {},
        "response": {
          "timestamp": "google.protobuf.Timestamp (RFC 3339)"
        },
        "credit_cost": 1
      }
    },
    "streams": {
      "GetPriorityFeeStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "description": "Real-time priority fee updates",
        "parameters": {
          "project": { "type": "enum", "values": ["P_JUPITER", "P_RAYDIUM"] },
          "percentile": { "type": "double", "default": 55 }
        },
        "response": {
          "project": "enum",
          "percentile": "double",
          "feeAtPercentile": "uint64 (micro lamports)"
        }
      },
      "GetBundleTipStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "description": "Real-time bundle tip percentile data",
        "parameters": {},
        "response": {
          "timestamp": "string",
          "percentile25": "uint64",
          "percentile50": "uint64",
          "percentile75": "uint64",
          "percentile95": "uint64",
          "percentile99": "uint64",
          "emaPercentile50": "uint64 (1-min EMA of 50th percentile)"
        }
      },
      "GetRecentBlockHashStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "description": "Streams the latest Solana blockhash for transaction construction."
      },
      "GetPumpFunNewAmmPoolStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "endpoint": "wss://pump-{region}.solana.dex.blxrbdn.com/ws",
        "description": "Streams new PumpFun AMM pool creation events."
      },
      "GetPumpFunNewTokensStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "endpoint": "wss://pump-{region}.solana.dex.blxrbdn.com/ws",
        "description": "Stream of new PumpFun token launches",
        "parameters": {},
        "response": {
          "slot": "int64",
          "txnHash": "string",
          "name": "string",
          "symbol": "string",
          "uri": "string",
          "mint": "string",
          "bondingCurve": "string",
          "creator": "string",
          "creatorVault": "string",
          "timestamp": "google.protobuf.Timestamp"
        }
      },
      "GetPumpFunSwapsStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "endpoint": "wss://pump-{region}.solana.dex.blxrbdn.com/ws",
        "description": "Stream of PumpFun bonding curve swap events",
        "parameters": {
          "tokens": {
            "type": "string[]",
            "description": "List of token addresses to track"
          }
        },
        "response": {
          "slot": "int64",
          "txnHash": "string",
          "mintAddress": "string",
          "userAddress": "string",
          "userTokenAccountAddress": "string",
          "bondingCurveAddress": "string",
          "tokenVaultAddress": "string",
          "solAmount": "uint64 (lamports)",
          "tokenAmount": "uint64",
          "isBuy": "boolean",
          "virtualSolReserves": "uint64",
          "virtualTokenReserves": "uint64",
          "creator": "string",
          "timestamp": "google.protobuf.Timestamp"
        }
      },
      "GetPumpFunAMMSwapsStream": {
        "protocol": "WebSocket",
        "ws_method": "subscribe",
        "endpoint": "wss://pump-{region}.solana.dex.blxrbdn.com/ws",
        "description": "Stream of PumpFun AMM pool swap events",
        "parameters": {
          "pools": {
            "type": "string[]",
            "description": "List of pool addresses to track"
          }
        },
        "response": {
          "slot": "int64",
          "pool": "string",
          "user": "string",
          "isBuy": "boolean",
          "quoteMint": "string",
          "baseMint": "string",
          "inAmount": "uint64",
          "outAmount": "uint64",
          "txHash": "string",
          "timestamp": "google.protobuf.Timestamp"
        }
      }
    },
    "pumpfun": {
      "quotes": {
        "method": "GET",
        "path": "/api/v2/pumpfun/quotes",
        "description": "Get PumpFun bonding curve quote",
        "base_urls": ["https://pump-ny.solana.dex.blxrbdn.com", "https://pump-uk.solana.dex.blxrbdn.com"],
        "parameters": {
          "quoteType": { "type": "string", "values": ["BUY", "SELL"] },
          "mintAddress": { "type": "string" },
          "bondingCurveAddress": { "type": "string" },
          "amount": { "type": "double" }
        },
        "response": {
          "quoteType": "string",
          "inTokenAddress": "string",
          "inAmount": "number",
          "outTokenAddress": "string",
          "outAmount": "number"
        }
      },
      "swap": {
        "method": "POST",
        "path": "/api/v2/pumpfun/swap",
        "description": "Build PumpFun bonding curve swap transaction (does NOT submit)",
        "base_urls": ["https://pump-ny.solana.dex.blxrbdn.com", "https://pump-uk.solana.dex.blxrbdn.com"],
        "parameters": {
          "userAddress": { "type": "string", "required": true },
          "bondingCurveAddress": { "type": "string", "required": true },
          "tokenAddress": { "type": "string", "required": true },
          "tokenAmount": { "type": "double", "required": true },
          "solThreshold": { "type": "double", "required": true, "description": "Max SOL for buys, min SOL for sells" },
          "isBuy": { "type": "boolean", "required": true },
          "slippage": { "type": "double", "required": true, "description": "0-1000" },
          "creator": { "type": "string", "required": true },
          "computeLimit": { "type": "uint64", "required": false },
          "computePrice": { "type": "uint64", "required": false },
          "tip": { "type": "uint64", "required": false }
        },
        "response": {
          "transaction": { "content": "base64 encoded transaction" }
        }
      },
      "swap_sol": {
        "method": "POST",
        "path": "/api/v2/pumpfun/swap-sol",
        "description": "Build PumpFun swap by SOL amount (does NOT submit)",
        "base_urls": ["https://pump-ny.solana.dex.blxrbdn.com", "https://pump-uk.solana.dex.blxrbdn.com"],
        "parameters": {
          "userAddress": { "type": "string", "required": true },
          "bondingCurveAddress": { "type": "string", "required": true },
          "tokenAddress": { "type": "string", "required": true },
          "solAmount": { "type": "double", "required": true },
          "creator": { "type": "string", "required": true },
          "slippage": { "type": "double", "required": true, "description": "0-1000" },
          "computeLimit": { "type": "uint32", "required": false },
          "computePrice": { "type": "uint64", "required": false },
          "tip": { "type": "uint64", "required": false }
        },
        "response": {
          "transaction": { "content": "base64 encoded unsigned transaction" }
        }
      },
      "amm_quotes": {
        "method": "GET",
        "path": "/api/v2/pumpfun/amm/quotes",
        "description": "Get PumpFun AMM pool quote",
        "base_urls": ["https://pump-ny.solana.dex.blxrbdn.com", "https://pump-uk.solana.dex.blxrbdn.com"],
        "parameters": {
          "inToken": { "type": "string", "required": true },
          "inAmount": { "type": "double", "required": true },
